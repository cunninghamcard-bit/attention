{
  "name": "obsidian-reconstructed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clean-room runnable reconstruction of Obsidian's frontend architecture for study.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p electron/tsconfig.json",
    "lint": "oxlint -c oxlint.json src --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "build:electron": "vite build --config vite.electron.config.ts",
    "start:desktop": "bun run build:electron && ELECTRON_RENDERER_URL=${ELECTRON_RENDERER_URL:-http://127.0.0.1:5173} electron dist-electron/main.cjs",
    "desktop": "bun run build && bun run build:electron && electron dist-electron/main.cjs",
    "check": "oxlint -c oxlint.json src --quiet && tsc --noEmit && bun run typecheck:electron && vitest run && vite build && bun run build:api && bun run build:electron",
    "build:analyze": "ANALYZE=1 vite build",
    "packcheck": "publint && attw --pack .",
    "quality": "bun run check && bun run e2e && bun run packcheck",
    "build:api": "vite build --config vite.api.config.ts && bun scripts/fix-dts-extensions.ts",
    "fix:dts": "bun scripts/fix-dts-extensions.ts",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@electron/remote": "^2.1.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "types": "dist/api/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/api/src/index.d.ts",
        "default": "./dist/api/index.js"
      },
      "require": {
        "types": "./dist/api/src/index.d.cts",
        "default": "./dist/api/index.cjs"
      },
      "default": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/collab": "^6.1.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "ghostty-web": "^0.4.0",
    "moment": "^2.30.1",
    "node-pty": "^1.1.0",
    "stream-markdown-parser": "1.0.9",
    "yaml": "^2.9.0"
  }
}
