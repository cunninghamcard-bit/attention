{
  "name": "monorepo-root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop agent workbench built on a clean-room reconstruction of Obsidian's frontend architecture.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 -c src/apps/web/vite.config.ts",
    "build": "vite build -c src/apps/web/vite.config.ts",
    "preview": "vite preview --host 127.0.0.1 -c src/apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p src/apps/desktop/tsconfig.json",
    "lint": "oxlint -c oxlint.json src --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "build:electron": "vite build --config src/apps/desktop/vite.config.ts",
    "build:server": "vite build --config src/apps/server/vite.config.ts",
    "start:desktop": "pnpm run build:electron && ELECTRON_RENDERER_URL=${ELECTRON_RENDERER_URL:-http://127.0.0.1:5173} electron dist-electron/main.cjs",
    "desktop": "pnpm run build && pnpm run build:electron && electron dist-electron/main.cjs",
    "check": "oxlint -c oxlint.json src --quiet && tsc --noEmit && pnpm run typecheck:electron && vitest run && pnpm run build && pnpm run build:api && pnpm run build:electron",
    "build:analyze": "ANALYZE=1 vite build -c src/apps/web/vite.config.ts",
    "packcheck": "publint && attw --pack .",
    "quality": "pnpm run check && pnpm run e2e && pnpm run packcheck",
    "build:api": "vite build --config src/apps/web/vite.api.config.ts && node scripts/fix-dts-extensions.ts",
    "fix:dts": "node scripts/fix-dts-extensions.ts",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; true",
    "test:e2e": "vitest run src/apps/web/src/builtin/agent/ChatE2E.test.ts",
    "e2e:cli": "node scripts/e2e-cli.mjs",
    "e2e:desktop": "playwright test -c playwright.desktop.config.ts",
    "preinstall": "node -e \"if(!/\\bpnpm\\//.test(process.env.npm_config_user_agent||''))throw new Error('Use pnpm to install dependencies (this repo is pnpm-only).')\""
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "electron": "^43.0.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^7.0.2",
    "vite": "latest",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0",
  "types": "dist/api/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/api/index.d.ts",
        "default": "./dist/api/index.js"
      },
      "require": {
        "types": "./dist/api/index.d.cts",
        "default": "./dist/api/index.cjs"
      },
      "default": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.11.0"
  }
}
