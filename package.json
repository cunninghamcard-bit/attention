{
  "name": "monorepo-root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop agent workbench built on a clean-room reconstruction of Obsidian's frontend architecture.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 -c apps/web/vite.config.ts",
    "build": "vite build -c apps/web/vite.config.ts",
    "preview": "vite preview --host 127.0.0.1 -c apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p apps/desktop/tsconfig.json",
    "lint": "oxlint -c oxlint.json apps tests scripts --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "build:electron": "vite build --config apps/desktop/vite.config.ts",
    "build:server": "vite build --config apps/server/vite.config.ts",
    "start:desktop": "pnpm run build:electron && ELECTRON_RENDERER_URL=${ELECTRON_RENDERER_URL:-http://127.0.0.1:5173} electron out/desktop/main.cjs",
    "desktop": "pnpm run build && pnpm run build:electron && electron out/desktop/main.cjs",
    "check": "pnpm run lint && pnpm run format:check && tsc --noEmit && pnpm run typecheck:electron && pnpm run typecheck:server && pnpm run typecheck:tools && vitest run && pnpm run build && pnpm run build:api && pnpm run build:electron && pnpm run build:server",
    "build:analyze": "ANALYZE=1 vite build -c apps/web/vite.config.ts",
    "packcheck": "publint && attw --pack .",
    "quality": "pnpm run check && pnpm run e2e && pnpm run packcheck",
    "build:api": "vite build --config apps/web/vite.api.config.ts && node scripts/fix-dts-extensions.ts",
    "fix:dts": "node scripts/fix-dts-extensions.ts",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; true",
    "test:e2e": "vitest run tests/web/builtin/agent/ChatE2E.test.ts",
    "e2e:cli": "node scripts/e2e-cli.mjs",
    "e2e:desktop": "playwright test -c tests/e2e/playwright.desktop.config.ts",
    "preinstall": "node -e \"if(!/\\bpnpm\\//.test(process.env.npm_config_user_agent||''))throw new Error('Use pnpm to install dependencies (this repo is pnpm-only).')\"",
    "typecheck:server": "tsc -p apps/server/tsconfig.json",
    "typecheck:tools": "tsc -p tsconfig.tools.json",
    "format": "oxfmt apps tests scripts",
    "format:check": "oxfmt --check apps tests scripts",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "e2e:perf": "PERF_VAULT=1 playwright test -c tests/e2e/playwright.config.ts perf/large-vault.spec.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "electron": "^43.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^7.0.2",
    "vite": "latest",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0",
  "types": "out/api/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./out/api/index.d.ts",
        "default": "./out/api/index.js"
      },
      "require": {
        "types": "./out/api/index.d.cts",
        "default": "./out/api/index.cjs"
      },
      "default": "./out/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11"
  }
}
