{
  "name": "obsidian-reconstructed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clean-room runnable reconstruction of Obsidian's frontend architecture for study.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c oxlint.json src --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "check": "oxlint -c oxlint.json src --quiet && tsc --noEmit && vitest run && vite build && bun run build:api",
    "build:analyze": "ANALYZE=1 vite build",
    "packcheck": "publint && attw --pack .",
    "quality": "bun run check && bun run e2e && bun run packcheck",
    "build:api": "vite build --config vite.api.config.ts && bun scripts/fix-dts-extensions.ts",
    "fix:dts": "bun scripts/fix-dts-extensions.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@playwright/test": "^1.61.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "types": "dist/api/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/api/src/index.d.ts",
        "default": "./dist/api/index.js"
      },
      "require": {
        "types": "./dist/api/src/index.d.cts",
        "default": "./dist/api/index.cjs"
      },
      "default": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/collab": "^6.1.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "moment": "^2.30.1",
    "yaml": "^2.9.0"
  }
}
