{
  "name": "workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop agent workbench built on a clean-room reconstruction of Obsidian's frontend architecture.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 -c src/renderer/vite.config.ts",
    "build": "vite build -c src/renderer/vite.config.ts",
    "preview": "vite preview --host 127.0.0.1 -c src/renderer/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p src/main/tsconfig.json",
    "lint": "oxlint -c oxlint.json src tests scripts --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "build:electron": "vite build --config src/main/vite.config.ts",
    "start:desktop": "pnpm run build:electron && ELECTRON_RENDERER_URL=${ELECTRON_RENDERER_URL:-http://127.0.0.1:5173} electron out/desktop/main.cjs",
    "desktop": "pnpm run build && pnpm run build:electron && electron out/desktop/main.cjs",
    "check": "pnpm run lint && pnpm run format:check && tsc --noEmit && pnpm run typecheck:electron && pnpm run typecheck:tools && vitest run && pnpm run build && pnpm run build:api && pnpm run build:electron",
    "build:analyze": "ANALYZE=1 vite build -c src/renderer/vite.config.ts",
    "packcheck": "publint && attw --pack .",
    "quality": "pnpm run check && pnpm run e2e && pnpm run packcheck",
    "build:api": "vite build --config src/renderer/vite.api.config.ts && node scripts/fix-dts-extensions.ts",
    "fix:dts": "node scripts/fix-dts-extensions.ts",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; true",
    "e2e:cli": "node scripts/e2e-cli.mjs",
    "e2e:desktop": "playwright test -c tests/e2e/playwright.desktop.config.ts",
    "preinstall": "node -e \"if(!/\\bpnpm\\//.test(process.env.npm_config_user_agent||''))throw new Error('Use pnpm to install dependencies (this repo is pnpm-only).')\"",
    "typecheck:tools": "tsc -p tsconfig.tools.json",
    "format": "oxfmt src tests scripts",
    "format:check": "oxfmt --check src tests scripts",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "e2e:perf": "PERF_VAULT=1 playwright test -c tests/e2e/playwright.config.ts perf/large-vault.spec.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/collab": "^6.1.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@electron/remote": "^2.1.3",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "1.0.0-beta.5",
    "font-list": "^2.1.0",
    "ghostty-web": "^0.4.0",
    "node-pty": "^1.1.0",
    "stream-markdown-parser": "1.0.9",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "electron": "^43.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.70.0",
    "publint": "^0.3.21",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^7.0.2",
    "vite": "latest",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0",
  "types": "out/api/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./out/api/index.d.ts",
        "default": "./out/api/index.js"
      },
      "require": {
        "types": "./out/api/index.d.cts",
        "default": "./out/api/index.cjs"
      },
      "default": "./out/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11"
  }
}
