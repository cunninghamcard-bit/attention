{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@web/*": ["./apps/web/*"],
      "@desktop/*": ["./apps/desktop/main/*"],
      "@preload/*": ["./apps/desktop/preload/*"],
      "@app/web/*": ["./apps/web/*"],
      "@app/shared/*": ["./packages/shared/*"],
      "@shared/*": ["./packages/shared/*"]
    }
  },
  "include": [
    "tests/e2e",
    "scripts",
    "vitest.config.ts",
    "apps/web/vite.config.ts",
    "apps/web/vite.api.config.ts",
    "apps/desktop/main/vite.config.ts"
  ]
}
