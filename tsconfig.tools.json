{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@web/*": [
        "./apps/web/src/*"
      ],
      "@desktop/*": [
        "./apps/desktop/*"
      ],
      "@app/web/*": [
        "./apps/web/src/*"
      ]
    }
  },
  "include": [
    "tests/e2e",
    "scripts",
    "vitest.config.ts",
    "apps/web/vite.config.ts",
    "apps/web/vite.api.config.ts",
    "apps/server/vite.config.ts"
  ]
}
